@model IEnumerable<MVCArchitecture.Models.Book>

@{
    ViewData["Title"] = "Book Library";
}

<div class="text-center">
    <h1 class="display-4">Book Library</h1>
    <p>This page demonstrates how the <strong>Model</strong> (Book data), <strong>View</strong> (this HTML page), and <strong>Controller</strong> (BooksController) work together.</p>
</div>

<div class="mb-3 text-start">
    <a asp-action="Create" class="btn btn-primary">Add New Book</a>
</div>

<table class="table table-striped table-hover mt-4">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Author</th>
            <th>Year Published</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Id</td>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.YearPublished</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-danger ms-1">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

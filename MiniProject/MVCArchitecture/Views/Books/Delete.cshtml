@model MVCArchitecture.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

<h3 class="text-danger mt-4">Are you sure you want to delete this?</h3>
<div class="mt-4">
    <h4>Book Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Title</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">Author</dt>
        <dd class="col-sm-9">@Model.Author</dd>

        <dt class="col-sm-3">Year Published</dt>
        <dd class="col-sm-9">@Model.YearPublished</dd>
    </dl>
    
    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Yes, Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel and Go Back</a>
    </form>
</div>

@model MVCArchitecture.Models.Book

@{
    ViewData["Title"] = "Edit Book";
}

<h1>Edit Book</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label asp-for="Title" class="control-label"></label>
                <input asp-for="Title" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Author" class="control-label"></label>
                <input asp-for="Author" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="YearPublished" class="control-label">Year Published</label>
                <input asp-for="YearPublished" class="form-control" type="number" required />
            </div>
            <div class="form-group mt-4">
                <input type="submit" value="Save" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>
